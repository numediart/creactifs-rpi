\mode<presentation>

\setbeamerfont{normal text}{size=\normalsize}
\setbeamerfont{subtitle}{size=\large, series=\mdseries}
\setbeamerfont{framesubtitle}{size=\large, shape=\itshape, series=\mdseries}
\setbeamerfont{author}{size=\large}
\setbeamerfont{date}{size=\small}

\if@bold
    \if@hugetitle
        \setbeamerfont{title}{size=\huge, series=\bfseries}
    \else
        \setbeamerfont{title}{size=\LARGE, series=\bfseries}
    \fi
    \setbeamerfont{frametitle}{size=\Large, series=\bfseries}
\else
    \if@hugetitle
        \setbeamerfont{title}{size=\huge, series=\mdseries}
    \else
        \setbeamerfont{title}{size=\LARGE, series=\mdseries}
    \fi
    \setbeamerfont{frametitle}{size=\Large, series=\mdseries}
\fi

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}

\if@thin
    \usepackage[sfdefault,light]{FiraSans}
\else
    \usepackage[sfdefault,lf]{carlito}
\fi
\usefonttheme[onlymath]{serif}

\usepackage{FiraMono}

\usepackage{listings}
\lstset{
    basicstyle=\footnotesize\ttfamily,
    breakatwhitespace=false,
    breaklines=true,
    commentstyle=\itshape\color{mfrancois@codecomment},
    extendedchars=true,
    keepspaces=true,
    language=Python,
    keywordstyle=\color{mfrancois@codekeyword},
    showspaces=false,
    showstringspaces=false,
    showtabs=false,
    stringstyle=\color{mfrancois@codestring}}

\mode<all>
